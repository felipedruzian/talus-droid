#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SERVICE_SOURCE="${ROOT_DIR}/systemd/talus-bringup.service"
SERVICE_TARGET="/etc/systemd/system/talus-bringup.service"

sudo cp "${SERVICE_SOURCE}" "${SERVICE_TARGET}"
sudo systemctl daemon-reload

cat <<EOF
Service installed at ${SERVICE_TARGET}

Next steps:
  sudo systemctl enable talus-bringup.service
  sudo systemctl start talus-bringup.service
  sudo systemctl status talus-bringup.service

To disable startup:
  sudo systemctl disable talus-bringup.service
EOF
