#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PROFILE="${1:-${TALUS_PROFILE:-floor_test}}"
ENABLE_TELEOP="${TALUS_ENABLE_TELEOP:-auto}"
ENABLE_KINECT="${TALUS_ENABLE_KINECT:-auto}"
SERIAL_PORT="${TALUS_SERIAL_PORT:-/dev/ttyUSB0}"
JOY_DEVICE_ID="${TALUS_JOY_DEVICE_ID:-0}"
KINECT_DRIVER_MODE="${TALUS_KINECT_DRIVER_MODE:-modular}"
RTABMAP_VIZ="${TALUS_RTABMAP_VIZ:-true}"
RVIZ="${TALUS_RVIZ:-false}"
USE_RGBD_SYNC="${TALUS_USE_RGBD_SYNC:-false}"
APPROX_SYNC="${TALUS_APPROX_SYNC:-true}"
APPROX_SYNC_MAX_INTERVAL="${TALUS_APPROX_SYNC_MAX_INTERVAL:-0.01}"
DEVICE_SETTLE_SECS="${TALUS_DEVICE_SETTLE_SECS:-0}"
ROS_DOMAIN_ID="${ROS_DOMAIN_ID:-42}"
RMW_IMPLEMENTATION="${RMW_IMPLEMENTATION:-rmw_cyclonedds_cpp}"

if [[ "${PROFILE}" == "--help" || "${PROFILE}" == "-h" ]]; then
  cat <<'EOF'
Usage: talus-up [floor_test|base|teleop|kinect|odom_test|slam]

Environment variables:
  TALUS_PROFILE=floor_test
  TALUS_ENABLE_TELEOP=auto|true|false
  TALUS_ENABLE_KINECT=auto|true|false
  TALUS_SERIAL_PORT=/dev/ttyUSB0
  TALUS_JOY_DEVICE_ID=0
  TALUS_KINECT_DRIVER_MODE=modular|unified
  TALUS_RTABMAP_VIZ=true|false
  TALUS_RVIZ=false|true
  TALUS_USE_RGBD_SYNC=false|true
  TALUS_APPROX_SYNC=true|false
  TALUS_APPROX_SYNC_MAX_INTERVAL=0.01
EOF
  exit 0
fi

set +u
source /opt/ros/jazzy/setup.bash
source "${ROOT_DIR}/install/setup.bash"
set -u
export ROS_DOMAIN_ID
export RMW_IMPLEMENTATION

has_joystick() {
  compgen -G "/dev/input/js*" >/dev/null
}

has_kinect() {
  command -v lsusb >/dev/null 2>&1 &&
    lsusb | grep -qiE 'Xbox NUI|045e:02ae|045e:02ad|045e:02b0'
}

resolve_feature() {
  local policy="$1"
  local detector="$2"

  case "${policy}" in
    true|false)
      printf '%s\n' "${policy}"
      ;;
    auto)
      if "${detector}"; then
        printf 'true\n'
      else
        printf 'false\n'
      fi
      ;;
    *)
      printf 'Invalid policy: %s\n' "${policy}" >&2
      exit 2
      ;;
  esac
}

ENABLE_TELEOP_RESOLVED="$(resolve_feature "${ENABLE_TELEOP}" has_joystick)"
ENABLE_KINECT_RESOLVED="$(resolve_feature "${ENABLE_KINECT}" has_kinect)"

echo "Talus profile: ${PROFILE}"
echo "Teleop enabled: ${ENABLE_TELEOP_RESOLVED}"
echo "Kinect enabled: ${ENABLE_KINECT_RESOLVED}"
echo "Kinect driver mode: ${KINECT_DRIVER_MODE}"
echo "ROS_DOMAIN_ID: ${ROS_DOMAIN_ID}"
echo "RMW_IMPLEMENTATION: ${RMW_IMPLEMENTATION}"

if [[ "${DEVICE_SETTLE_SECS}" != "0" ]]; then
  echo "Waiting ${DEVICE_SETTLE_SECS}s for device settle"
  sleep "${DEVICE_SETTLE_SECS}"
  ENABLE_TELEOP_RESOLVED="$(resolve_feature "${ENABLE_TELEOP}" has_joystick)"
  ENABLE_KINECT_RESOLVED="$(resolve_feature "${ENABLE_KINECT}" has_kinect)"
  echo "Teleop rechecked: ${ENABLE_TELEOP_RESOLVED}"
  echo "Kinect rechecked: ${ENABLE_KINECT_RESOLVED}"
fi

case "${PROFILE}" in
  floor_test|floor)
    exec ros2 launch talus_bringup floor_test.launch.py \
      serial_port:="${SERIAL_PORT}" \
      joy_device_id:="${JOY_DEVICE_ID}" \
      kinect_driver_mode:="${KINECT_DRIVER_MODE}" \
      enable_teleop:="${ENABLE_TELEOP_RESOLVED}" \
      enable_kinect:="${ENABLE_KINECT_RESOLVED}"
    ;;
  base)
    exec ros2 launch talus_bringup base.launch.py \
      serial_port:="${SERIAL_PORT}"
    ;;
  teleop)
    if [[ "${ENABLE_TELEOP_RESOLVED}" != "true" ]]; then
      echo "Joystick not detected and teleop policy resolved to false." >&2
      exit 1
    fi
    exec ros2 launch talus_bringup teleop.launch.py \
      joy_device_id:="${JOY_DEVICE_ID}"
    ;;
  kinect)
    if [[ "${ENABLE_KINECT_RESOLVED}" != "true" ]]; then
      echo "Kinect not detected and kinect policy resolved to false." >&2
      exit 1
    fi
    exec ros2 launch talus_bringup kinect.launch.py \
      driver_mode:="${KINECT_DRIVER_MODE}"
    ;;
  odom_test|odom)
    if [[ "${ENABLE_KINECT_RESOLVED}" != "true" ]]; then
      echo "Kinect not detected and odom profile cannot start." >&2
      exit 1
    fi
    exec ros2 launch talus_bringup odom_test.launch.py \
      serial_port:="${SERIAL_PORT}" \
      kinect_driver_mode:="${KINECT_DRIVER_MODE}" \
      use_rgbd_sync:="${USE_RGBD_SYNC}" \
      approx_sync:="${APPROX_SYNC}" \
      approx_sync_max_interval:="${APPROX_SYNC_MAX_INTERVAL}"
    ;;
  slam)
    if [[ "${ENABLE_KINECT_RESOLVED}" != "true" ]]; then
      echo "Kinect not detected and slam profile cannot start." >&2
      exit 1
    fi
    exec ros2 launch talus_bringup slam_rtabmap.launch.py \
      use_rgbd_sync:="${USE_RGBD_SYNC}" \
      approx_sync:="${APPROX_SYNC}" \
      approx_sync_max_interval:="${APPROX_SYNC_MAX_INTERVAL}" \
      rtabmap_viz:="${RTABMAP_VIZ}" \
      rviz:="${RVIZ}"
    ;;
  *)
    echo "Unknown profile: ${PROFILE}" >&2
    exit 2
    ;;
esac
